{
  "description": "Injects Codex context when the Codex plugin is enabled — full briefing at session start, a compact guardrail at subagent start. Chooses base vs extended by the installed plugin's actual capability.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-codex-context.sh\" SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-codex-context.sh\" SubagentStart",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
